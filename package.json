{
  "name": "andreabozzo-site",
  "private": true,
  "scripts": {
    "build:assets": "npm run build:wasm && npm run build:css && npm run build:js",
    "build:blog": "cd blog && hugo --minify -F --config hugo.toml,hugo.github.toml",
    "build:css": "esbuild assets/styles.css --bundle --minify --outfile=assets/styles.min.css",
    "build:js": "esbuild assets/main.js --bundle --format=iife --minify --outfile=assets/main.min.js",
    "build:wasm": "bash ./scripts/build-wasm.sh",
    "generate:svg": "node ./scripts/generate-case-study-svgs.mjs",
    "generate:og": "node ./scripts/generate-og-images.mjs",
    "generate:case-studies": "go run ./cmd/harvester generate-case-study-pages",
    "generate:contributions": "go run ./cmd/harvester generate-contributions-json",
    "generate:writing": "go run ./cmd/harvester generate-writing-index",
    "generate:packages": "go run ./cmd/harvester generate-package-registry-index",
    "generate:ci": "go run ./cmd/harvester generate-ci-runtime-index",
    "generate:datasets": "go run ./cmd/harvester generate-dataset-index",
    "generate:repo-metadata": "go run ./cmd/harvester generate-repository-metadata-index",
    "generate:contracts": "go run ./cmd/harvester generate-contract-artifacts",
    "harvester:artifacts": "go run ./cmd/harvester generate-static-artifacts",
    "refresh:data": "go run ./cmd/harvester ingest --all",
    "harvester:readme": "go run ./cmd/harvester update-contributions-readme",
    "lint:js": "eslint assets/main.js assets/workbench/*.js sw.js",
    "lint:css-tokens": "node ./scripts/check-css-tokens.mjs",
    "validate:data": "node ./scripts/validate-data.mjs",
    "vercel:prepare-prebuilt": "node ./scripts/materialize-vercel-go-bootstraps.mjs",
    "vercel:deploy:prebuilt": "npx vercel build && npm run vercel:prepare-prebuilt && npx vercel deploy --prebuilt",
    "lint:svg": "node ./scripts/validate-svg.mjs",
    "optimize:svg": "svgo -r assets/images/case-studies",
    "assemble:site": "bash ./scripts/assemble-site.sh",
    "validate:localization": "go run ./cmd/harvester validate-localization",
    "build:site": "npm run generate:svg && npm run generate:og && npm run build:assets && npm run build:blog && npm run harvester:artifacts && npm run assemble:site && npm run validate:localization",
    "test:smoke": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.11",
    "eslint": "^10.3.0",
    "fontkit": "^2.0.4",
    "globals": "^17.6.0",
    "opentype.js": "^2.0.0",
    "svgo": "^4.0.1"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  }
}
