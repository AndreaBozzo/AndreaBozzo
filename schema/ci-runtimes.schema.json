{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://andreabozzo.dev/schema/ci-runtimes.schema.json",
  "title": "CIRuntimeIndexV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schemaVersion", "generatedAt", "source", "items"],
  "properties": {
    "$schemaVersion": {
      "const": "v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CIRuntimeItemV1"
      }
    }
  },
  "$defs": {
    "CIRuntimeItemV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caseStudySlug",
        "repoFullName",
        "repoUrl",
        "workflowName",
        "runsSampled",
        "medianDurationSeconds",
        "p95DurationSeconds",
        "successRate"
      ],
      "properties": {
        "caseStudySlug": {
          "type": "string",
          "minLength": 1
        },
        "repoFullName": {
          "type": "string",
          "minLength": 1
        },
        "repoUrl": {
          "type": "string",
          "format": "uri"
        },
        "workflowName": {
          "type": "string",
          "minLength": 1
        },
        "workflowPath": {
          "type": "string"
        },
        "workflowUrl": {
          "type": "string",
          "format": "uri"
        },
        "runsSampled": {
          "type": "integer",
          "minimum": 0
        },
        "medianDurationSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "p95DurationSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "successRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "latestStatus": {
          "type": "string"
        },
        "latestConclusion": {
          "type": "string"
        },
        "latestRunAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
